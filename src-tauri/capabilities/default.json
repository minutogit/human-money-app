{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "clipboard-manager:allow-write-text",
    "log:default",
    "dialog:allow-save",
    "fs:allow-write-file",
    {
      "identifier": "fs:scope",
      "allow": ["**"]
    }
  ]
}